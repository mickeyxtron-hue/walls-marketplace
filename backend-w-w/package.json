{
  "name": "wheels-walls-backend",
  "version": "1.0.0",
  "description": "Backend for Wheels & Walls Marketplace",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"cd .. && live-server frontend-w-w --port=5500 --host=localhost\"",
    "dev-simple": "nodemon server.js",
    "frontend": "cd .. && live-server frontend-w-w --port=5500 --host=localhost",
    "both": "concurrently \"npm run dev-simple\" \"npm run frontend\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-facebook": "^3.0.0",
    "express-session": "^1.17.3",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  }
}