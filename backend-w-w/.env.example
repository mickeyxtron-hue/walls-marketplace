# === Wheels & Walls Environment Configuration Example ===

# Backend API Base URL
# If you're running the backend locally, use http://localhost:3000
VITE_API_BASE=http://localhost:3000

# Toggle backend usage
# true  = use API (requires server.js running)
# false = use localStorage only (frontend-only mode)
VITE_USE_API=true

# App Identity
VITE_APP_NAME="Wheels & Walls"
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_THEME=light

# Optional Third-Party Keys (Uncomment and fill if using)
# VITE_GOOGLE_MAPS_KEY=
# VITE_FIREBASE_KEY=
# VITE_CLOUDINARY_UPLOAD_URL=
